# ============================================================
# NEXUS POS — Production Environment Variables
# Copy to .env and fill in values before deploying
# ============================================================

# App
NODE_ENV=production
PORT=3001

# URLs (update with your actual domains)
NEXT_PUBLIC_APP_URL=https://app.nexuspos.app
NEXT_PUBLIC_API_URL=https://api.nexuspos.app

# Database (Supabase connection pooler — Session mode port 5432 or Transaction mode 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# Redis (Upstash recommended — copy from upstash.io dashboard)
REDIS_URL=rediss://:[password]@[region].upstash.io:6380

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# Wompi (billing — Colombia — get from dashboard.wompi.co)
WOMPI_PUBLIC_KEY=pub_prod_...
WOMPI_PRIVATE_KEY=prv_prod_...
WOMPI_EVENTS_SECRET=prod_events_secret_...

# WhatsApp (Meta Business API)
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend — resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@nexuspos.app

# DIAN (Colombia electronic invoicing)
DIAN_NIT=your_nit
DIAN_CERT_PATH=/app/certs/dian.pfx
DIAN_CERT_PASSWORD=your_cert_password
