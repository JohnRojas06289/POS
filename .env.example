JWT_REFRESH_EXPIRES="30d"

# Backend
PORT="3001"
NODE_ENV="development"
BACKEND_URL="http://localhost:3001"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

